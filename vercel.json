{
  "version": 2,
  "public": false,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/quiz", "dest": "/public/quiz.html" },
    { "src": "/result", "dest": "/public/result.html" },
    { "src": "/login", "dest": "/public/login.html" },
    { "src": "/login.html", "dest": "/public/login.html" },
    { "src": "/", "dest": "/public/index.html" }
  ]
}
