{
  "rewrites": [
    {
      "source": "/css/(.*)",
      "destination": "/public/css/"
    },
    {
      "source": "/js/(.*)",
      "destination": "/public/js/"
    },
    {
      "source": "/admin",
      "destination": "/public/admin.html"
    },
    {
      "source": "/quiz",
      "destination": "/public/quiz.html"
    },
    {
      "source": "/result",
      "destination": "/public/result.html"
    },
    {
      "source": "/login",
      "destination": "/public/login.html"
    },
    {
      "source": "/login.html",
      "destination": "/public/login.html"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    }
  ]
}